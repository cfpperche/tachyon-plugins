{
  "name": "agent-browser",
  "version": "2.1.0",
  "description": "Give an agent eyes + hands on the web. Tachyon fetches the pinned, checksum-verified agent-browser CLI (a native Chrome-driving binary) and ships a runtime-neutral skill: open a page, get an accessibility snapshot with @eN refs, screenshot, and extract content \u2014 including from auth-gated pages via the CLI's saved-session state (the LLM never sees a credential). A MECHANICAL write gate holds every state-mutating action (click/fill/type/submit/upload/eval/download) for an explicit confirmation; reads (navigate/snapshot/screenshot/extract) stay frictionless. v2.1 makes the gate HUMAN-CONFIGURABLE: edit the bundled agent-browser config (native confirmActions / allowedDomains / timeouts; published schema) through the Plugins Config editor \u2014 Tachyon feeds your config to the CLI and refuses the agent's attempts to override it. Needs a host Chrome/Chromium.",
  "runtimes": [
    "claude",
    "codex"
  ],
  "config": {
    "file": "config/agent-browser.json",
    "schemaFile": "config/schema.json"
  },
  "docsUrl": "https://github.com/cfpperche/tachyon-plugins/tree/main/agent-browser",
  "tools": {
    "agent-browser": {
      "version": "0.31.0",
      "launchPolicy": {
        "configArg": "--config",
        "scrubEnv": [
          "AGENT_BROWSER_CONFIRM_ACTIONS",
          "AGENT_BROWSER_ACTION_POLICY",
          "AGENT_BROWSER_CONFIG",
          "AGENT_BROWSER_INIT_SCRIPTS",
          "AGENT_BROWSER_EXTENSIONS",
          "AGENT_BROWSER_PLUGINS",
          "AGENT_BROWSER_CDP",
          "AGENT_BROWSER_AUTO_CONNECT",
          "AGENT_BROWSER_ARGS"
        ],
        "denyArgs": [
          "--confirm-actions",
          "--action-policy",
          "--config",
          "--init-script",
          "--extension",
          "--cdp",
          "--auto-connect",
          "--args",
          "addinitscript",
          "connect",
          "mcp",
          "batch"
        ],
        "mode": "force"
      },
      "platforms": {
        "linux-x64-glibc": {
          "url": "https://github.com/vercel-labs/agent-browser/releases/download/v0.31.0/agent-browser-linux-x64",
          "sha256": "71dbe415ab3ded286c71eca67933575eb9f451be9155283a2e3a1ab878d75eff"
        },
        "linux-x64-musl": {
          "url": "https://github.com/vercel-labs/agent-browser/releases/download/v0.31.0/agent-browser-linux-musl-x64",
          "sha256": "8d355ca93f95d3bae47aad6509433ab2312384fee81eb39a903ad5fade38f4e8"
        },
        "linux-arm64-glibc": {
          "url": "https://github.com/vercel-labs/agent-browser/releases/download/v0.31.0/agent-browser-linux-arm64",
          "sha256": "bb2827dede43536e402cba8bc74249cdaa5af9aee291d185083c7bbdb7d62b14"
        },
        "linux-arm64-musl": {
          "url": "https://github.com/vercel-labs/agent-browser/releases/download/v0.31.0/agent-browser-linux-musl-arm64",
          "sha256": "0506cb206c39c75b746d16571a75dc2752cd9968e154dcb8a0e203614552d392"
        },
        "darwin-x64": {
          "url": "https://github.com/vercel-labs/agent-browser/releases/download/v0.31.0/agent-browser-darwin-x64",
          "sha256": "a53b1156dd36f1a11e324a1aa45636f481b09aa690ea774d10776446dc758bfa"
        },
        "darwin-arm64": {
          "url": "https://github.com/vercel-labs/agent-browser/releases/download/v0.31.0/agent-browser-darwin-arm64",
          "sha256": "21da37d1e3707786ca5ceb04455bdeccaf93fa9077e3983a6f4dcce52817c4d8"
        }
      }
    }
  }
}
