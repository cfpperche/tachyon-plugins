{
  "name": "secrets-guard",
  "version": "2.0.1",
  "description": "A two-layer git secrets gate powered by gitleaks. Layer 1: a pre-commit git-hook scans staged changes (Tachyon fetches the pinned, checksum-verified gitleaks binary). Layer 2: a per-runtime PreToolUse shape-gate stops an agent from silently bypassing layer 1 via --no-verify / compound / -a. Together they make the gate hard to slip \u2014 for you, the agent, and your IDE.",
  "runtimes": [
    "claude",
    "codex"
  ],
  "blocks": {
    "claude": "claude/",
    "codex": "codex/"
  },
  "gitHooks": {
    "pre-commit": {
      "argv": [
        "${tool:gitleaks}",
        "protect",
        "--staged",
        "--no-banner",
        "--redact"
      ]
    }
  },
